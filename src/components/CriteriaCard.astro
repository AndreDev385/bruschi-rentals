---
const { Icon, name, value } = Astro.props;
---

<div
  class="flex items-center space-x-3 px-4 py-2 bg-card rounded-lg shadow-s hover:shadow-m transition-shadow"
>
  <Icon />
  <div>
    <div class="text-xs font-medium text-gray-500">
      {name}
    </div>
    <div class="text-gray-900">
      {value}
    </div>
  </div>
</div>
