---
import { ClientRouter } from "astro:transitions";
import { Toaster } from "sonner";
import "sonner/dist/styles.css";

import "../styles/global.css";
import "animate.css";

// Cloudflare Turnstile - Bot protection
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "";
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        // @ts-ignore: Unos errores TS7015 aquí son aceptables por ahora
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-PKWF9HXM");
    </script>
    <!-- End Google Tag Manager -->

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="logos/isotype.svg"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/svg+xml"
      href="logos/isotype_dark.svg"
      media="(prefers-color-scheme: dark)"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Bruschi Rentals</title>

    <!-- Font Preloading for Performance -->
    <link
      rel="preload"
      href="/fonts/quinn-bold.otf"
      as="font"
      type="font/otf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/bell-bold.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/oxygen.ttf"
      as="font"
      type="font/ttf"
      crossorigin
    />

    <ClientRouter />

    <!-- Cloudflare Turnstile - Bot Protection -->
    {
      siteKey && (
        <script
          is:inline
          src="https://challenges.cloudflare.com/turnstile/v0/api.js"
          async
          defer
        />
      )
    }
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-PKWF9HXM"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <slot />
    <Toaster client:idle />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
